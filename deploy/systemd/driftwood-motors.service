[Unit]
Description=Driftwood motor controller
After=network-online.target driftwood-data.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/driftwood/scripts
# Allow the data fetcher to populate CSVs before motors start (replaces old rc.local sleep)
ExecStartPre=/bin/sleep 120
ExecStart=/usr/bin/python3 /home/pi/driftwood/scripts/project_log_live.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
